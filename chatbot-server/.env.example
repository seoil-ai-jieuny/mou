# Google Gemini API 키 (필수)
# 발급: https://aistudio.google.com/apikey (Google 계정만 있으면 무료, 카드 등록 불필요)
GEMINI_API_KEY=your-gemini-api-key-here

# 사용할 모델 (기본값 권장)
# - 채팅: gemini-2.5-flash (무료 10 RPM·250 RPD)
#   더 여유로운 한도가 필요하면: gemini-2.5-flash-lite (15 RPM·1000 RPD, 품질 약간↓)
# - 임베딩: gemini-embedding-001 (정식 GA)
CHAT_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# 임베딩 출력 차원 (768/1536/3072 중 선택. 클수록 정확, 작을수록 검색 빠름)
EMBED_DIM=768

# Chroma DB 저장 경로
CHROMA_DIR=./chroma_db

# 인덱싱할 HTML 파일 경로 (index.html)
INDEX_HTML_PATH=../index.html

# 추가 문서가 들어있는 폴더 (PDF, TXT, MD 지원)
DOCS_DIR=./docs

# CORS 허용 오리진 (콤마 구분, * 는 모두 허용)
CORS_ORIGINS=*

# 규정 QA 지식(JSONL) 폴더 (단일 지식 출처)
KNOWLEDGE_DIR=./knowledge
